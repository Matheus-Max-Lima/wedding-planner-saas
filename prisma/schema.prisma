generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  password             String?
  emailVerified        DateTime?
  image                String?
  plan                 String    @default("free") // free, pro, premium
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  wedding              Wedding?
  passwordResetTokens  PasswordResetToken[]
  notifications        Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wedding {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  brideName                 String
  groomName                 String
  weddingDate               DateTime
  venue                     String?
  city                      String?
  totalBudget               Float    @default(0)
  guestCount                Int      @default(0)
  theme                     String?
  style                     String?
  spotifyAccessToken        String?  @db.Text
  spotifyRefreshToken       String?  @db.Text
  spotifyExpiresAt          DateTime?
  googleCalendarAccessToken String?  @db.Text
  googleCalendarRefreshToken String? @db.Text
  googleCalendarExpiresAt   DateTime?
  googleCalendarId          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  budgetItems   BudgetItem[]
  guests        Guest[]
  tables        Table[]
  vendors       Vendor[]
  timelineItems TimelineItem[]
  gifts         Gift[]
  inspirations  Inspiration[]
  playlists     Playlist[]
  honeymoon     Honeymoon?
  bachelorette  Bachelorette?
  trousseauItems TrousseauItem[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  description String?
  category    String
  month       Int      // months before wedding (1-12+)
  completed   Boolean  @default(false)
  dueDate     DateTime?
  priority    String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model BudgetItem {
  id           String   @id @default(cuid())
  weddingId    String
  category     String
  title        String
  estimatedCost Float   @default(0)
  actualCost   Float    @default(0)
  paid         Float    @default(0)
  vendor       String?
  notes        String?
  installments BudgetInstallment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model BudgetInstallment {
  id           String   @id @default(cuid())
  budgetItemId String
  amount       Float
  dueDate      DateTime
  paid         Boolean  @default(false)
  paidDate     DateTime?
  notes        String?
  createdAt    DateTime @default(now())

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
}

model Guest {
  id           String   @id @default(cuid())
  weddingId    String
  name         String
  email        String?
  phone        String?
  side         String   @default("both") // bride, groom, both
  status       String   @default("pending") // confirmed, declined, pending
  plusOne      Boolean  @default(false)
  plusOneName  String?
  dietary      String?
  tableId      String?
  notes        String?
  inviteSent   Boolean  @default(false)
  rsvpToken    String?  @unique
  rsvpRespondedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wedding Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  table   Table?   @relation(fields: [tableId], references: [id])
}

model Table {
  id          String   @id @default(cuid())
  weddingId   String
  name        String
  capacity    Int      @default(8)
  shape       String   @default("round") // round, rectangular
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests  Guest[]
}

model Vendor {
  id           String   @id @default(cuid())
  weddingId    String
  category     String
  name         String
  contact      String?
  email        String?
  phone        String?
  website      String?
  price        Float?
  status       String   @default("prospect") // prospect, contacted, hired, rejected
  rating       Int?
  notes        String?
  contractUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model TimelineItem {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  description String?
  date        String?
  startTime   String
  endTime     String?
  location    String?
  responsible String?
  category    String   @default("ceremony") // ceremony, reception, preparation, travel
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Gift {
  id          String   @id @default(cuid())
  weddingId   String
  name        String
  description String?
  price       Float?
  category    String?
  imageUrl    String?
  storeUrl    String?
  storeName   String?
  reserved    Boolean  @default(false)
  reservedBy  String?
  received    Boolean  @default(false)
  priority    String   @default("medium")
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Inspiration {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  imageUrl    String
  category    String
  notes       String?
  tags        String[]
  favorite    Boolean  @default(false)
  sourceUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Playlist {
  id          String   @id @default(cuid())
  weddingId   String
  name        String
  description String?
  moment      String   // ceremony, cocktail, reception, party
  tracks      Track[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Track {
  id         String   @id @default(cuid())
  playlistId String
  title      String
  artist     String
  spotifyId  String?
  duration   Int?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model Honeymoon {
  id          String   @id @default(cuid())
  weddingId   String   @unique
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  budget      Float    @default(0)
  notes       String?
  status      String   @default("planning")
  activities  HoneymoonActivity[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model HoneymoonActivity {
  id          String   @id @default(cuid())
  honeymoonId String
  title       String
  description String?
  date        DateTime?
  cost        Float?
  booked      Boolean  @default(false)
  category    String   @default("activity")
  createdAt   DateTime @default(now())

  honeymoon Honeymoon @relation(fields: [honeymoonId], references: [id], onDelete: Cascade)
}

model Bachelorette {
  id          String   @id @default(cuid())
  weddingId   String   @unique
  type        String   @default("bachelorette") // bachelorette, bachelor
  date        DateTime?
  location    String?
  budget      Float    @default(0)
  theme       String?
  notes       String?
  activities  BacheloretteActivity[]
  guests      BacheloretteGuest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model BacheloretteActivity {
  id             String   @id @default(cuid())
  bacheloretteId String
  title          String
  description    String?
  time           String?
  cost           Float?
  confirmed      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  bachelorette Bachelorette @relation(fields: [bacheloretteId], references: [id], onDelete: Cascade)
}

model BacheloretteGuest {
  id             String   @id @default(cuid())
  bacheloretteId String
  name           String
  email          String?
  phone          String?
  confirmed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  bachelorette Bachelorette @relation(fields: [bacheloretteId], references: [id], onDelete: Cascade)
}

model TrousseauItem {
  id          String   @id @default(cuid())
  weddingId   String
  name        String
  category    String
  quantity    Int      @default(1)
  acquired    Boolean  @default(false)
  brand       String?
  price       Float?
  notes       String?
  priority    String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, warning, success, error
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
