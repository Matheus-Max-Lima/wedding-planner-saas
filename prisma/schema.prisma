generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  wedding  Wedding?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wedding {
  id          String    @id @default(cuid())
  userId      String    @unique
  brideName   String
  groomName   String
  weddingDate DateTime?
  venue       String?
  city        String?
  totalBudget Float     @default(0)
  guestCount  Int?
  theme       String?
  style       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  budgetItems    BudgetItem[]
  guests         Guest[]
  tables         Table[]
  vendors        Vendor[]
  timelineItems  TimelineItem[]
  gifts          Gift[]
  inspirations   Inspiration[]
  playlists      Playlist[]
  honeymoon      Honeymoon?
  bachelorette   Bachelorette?
  trousseauItems TrousseauItem[]
}

model ChecklistItem {
  id        String    @id @default(cuid())
  weddingId String
  title     String
  category  String    @default("Outros")
  completed Boolean   @default(false)
  dueDate   DateTime?
  notes     String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model BudgetItem {
  id            String   @id @default(cuid())
  weddingId     String
  category      String
  description   String
  estimatedCost Float    @default(0)
  actualCost    Float    @default(0)
  paid          Boolean  @default(false)
  vendor        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wedding      Wedding             @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  installments BudgetInstallment[]
}

model BudgetInstallment {
  id           String   @id @default(cuid())
  budgetItemId String
  amount       Float
  dueDate      DateTime
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now())

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
}

model Guest {
  id          String    @id @default(cuid())
  weddingId   String
  name        String
  email       String?
  phone       String?
  status      String    @default("PENDING")
  group       String?
  plusOne     Boolean   @default(false)
  plusOneName String?
  tableId     String?
  notes       String?
  rsvpDate    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  table   Table?  @relation(fields: [tableId], references: [id])
}

model Table {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  capacity  Int      @default(8)
  shape     String   @default("ROUND")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests  Guest[]
}

model Vendor {
  id              String   @id @default(cuid())
  weddingId       String
  name            String
  category        String
  contactName     String?
  email           String?
  phone           String?
  website         String?
  price           Float    @default(0)
  paid            Boolean  @default(false)
  contractSigned  Boolean  @default(false)
  rating          Int?
  notes           String?
  status          String   @default("PROSPECT")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model TimelineItem {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  description String?
  startTime   String
  endTime     String?
  location    String?
  responsible String?
  category    String   @default("Cerimônia")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Gift {
  id               String   @id @default(cuid())
  weddingId        String
  name             String
  category         String   @default("Casa")
  store            String?
  url              String?
  price            Float    @default(0)
  quantity         Int      @default(1)
  quantityReceived Int      @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Inspiration {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  category    String   @default("Decoração")
  imageUrl    String?
  description String?
  tags        String[]
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Playlist {
  id          String   @id @default(cuid())
  weddingId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  tracks  Track[]
}

model Track {
  id         String   @id @default(cuid())
  playlistId String
  title      String
  artist     String?
  duration   String?
  spotifyUrl String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model Honeymoon {
  id          String    @id @default(cuid())
  weddingId   String    @unique
  destination String    @default("")
  startDate   DateTime?
  endDate     DateTime?
  budget      Float     @default(0)
  totalSpent  Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  wedding    Wedding             @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  activities HoneymoonActivity[]
}

model HoneymoonActivity {
  id               String    @id @default(cuid())
  honeymoonId      String
  title            String
  date             DateTime?
  time             String?
  description      String?
  cost             Float     @default(0)
  booked           Boolean   @default(false)
  confirmationCode String?
  createdAt        DateTime  @default(now())

  honeymoon Honeymoon @relation(fields: [honeymoonId], references: [id], onDelete: Cascade)
}

model Bachelorette {
  id        String    @id @default(cuid())
  weddingId String    @unique
  theme     String?
  date      DateTime?
  location  String?
  budget    Float     @default(0)
  totalSpent Float    @default(0)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  wedding             Wedding               @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  activities          BacheloretteActivity[]
  bacheloretteGuests  BacheloretteGuest[]
}

model BacheloretteActivity {
  id             String   @id @default(cuid())
  bacheloretteId String
  title          String
  time           String?
  description    String?
  cost           Float    @default(0)
  createdAt      DateTime @default(now())

  bachelorette Bachelorette @relation(fields: [bacheloretteId], references: [id], onDelete: Cascade)
}

model BacheloretteGuest {
  id             String   @id @default(cuid())
  bacheloretteId String
  name           String
  confirmed      Boolean  @default(false)
  paid           Boolean  @default(false)
  amountPaid     Float    @default(0)
  createdAt      DateTime @default(now())

  bachelorette Bachelorette @relation(fields: [bacheloretteId], references: [id], onDelete: Cascade)
}

model TrousseauItem {
  id             String   @id @default(cuid())
  weddingId      String
  name           String
  category       String   @default("Cama")
  quantity       Int      @default(1)
  quantityOwned  Int      @default(0)
  estimatedPrice Float    @default(0)
  store          String?
  priority       String   @default("MEDIUM")
  purchased      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}
